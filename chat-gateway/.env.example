# ==========================================
# Налаштування середовища (Environment Variables)
# Скопіюйте цей файл у .env та змініть значення при потребі
# ==========================================

# Тип середовища: development (для розробки) або production (на сервері)
ENVIRONMENT=production

# ==========================================
# Налаштування Штучного Інтелекту (LM Studio)
# ==========================================
# URL до вашого локального або віддаленого LM Studio сервера
LMSTUDIO_URL=http://192.168.1.85:1234/v1

# Назва моделі, яка відповідає за генерацію тексту (має збігатися з тим, що в LM Studio)
LLM_MODEL=gemma-4

# Назва моделі для векторного пошуку
EMBED_MODEL=bge-m3

# ==========================================
# Бази Даних (URL підключення)
# (Ці значення вже налаштовані для docker-compose)
# ==========================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/chatbot
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# ==========================================
# Безпека та Доступи
# ОБОВ'ЯЗКОВО ЗМІНІТЬ ЦІ ЗНАЧЕННЯ В PRODUCTION!
# ==========================================

# Ключ для шифрування сесій адмінки (мінімум 32 символи)
SECRET_KEY=super-secret-key-change-me-in-production

# Ключ для шифрування токенів Telegram/Viber (генерація: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=super-secret-fernet-key-change-me

# Пароль для входу в адмін-панель (логін завжди: admin)
ADMIN_DEFAULT_PASSWORD=admin123
